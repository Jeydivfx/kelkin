<resources>

    <style name="Theme.Kelkin" parent="Theme.MaterialComponents.NoActionBar">
        <item name="android:fontFamily">@font/yekanbakh_regular</item>
        <item name="colorPrimary">@color/netflix_red</item>
        <item name="android:windowBackground">@color/bg_black</item>
    </style>

    <style name="Theme.Kelkin.NoActionBar.FullScreen" parent="Theme.MaterialComponents.NoActionBar">
    <item name="android:windowFullscreen">true</item>
    <item name="android:windowContentOverlay">@null</item>
    <item name="android:windowBackground">#0F0F0F</item> </style>

    <style name="Theme.AppCompat.NoActionBar.FullScreen" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <style name="CustomAlertDialog" parent="Theme.AppCompat.DayNight.Dialog.Alert">
        <item name="android:windowBackground">@color/bg_black</item>
        <item name="android:textColorPrimary">@color/text_white</item>
        <item name="colorAccent">@color/netflix_red</item>
    </style>

    <style name="EnglishTitleStyle">
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">#99BCBCBC</item>
        <item name="android:fontFamily">@font/montserrat_regular</item>
    </style>

    <style name="SettingHeader">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingTop">24dp</item>
        <item name="android:paddingBottom">8dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:textColor">#FFD700</item> <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>



    <style name="SideBarItemStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">18dp</item>
        <item name="android:gravity">center_vertical|right</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:focusable">true</item>
        <item name="android:clickable">true</item>
        <item name="android:clipChildren">false</item>
        <item name="android:background">@android:color/transparent</item>
    </style>

    <style name="SideBarTextStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginEnd">12dp</item>
        <item name="android:textSize">14sp</item> <item name="android:textColor">@color/nav_item_color</item> <item name="android:alpha">0</item>
        <item name="android:fontFamily">@font/vazirmatn_bold</item>
        <item name="android:duplicateParentState">true</item> </style>

    <style name="SideBarIconStyle">
        <item name="android:layout_width">24dp</item> <item name="android:layout_height">20dp</item>
        <item name="android:duplicateParentState">true</item>
        <item name="tint">@color/nav_item_color</item> </style>

    <style name="SettingCard">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">12dp</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardBackgroundColor">#1AFFFFFF</item>
        <item name="cardElevation">0dp</item>
        <item name="android:foreground">@drawable/bg_setting_selector</item>
    </style>

    <style name="SettingItemText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">65dp</item>
        <item name="android:textColor">@color/text_setting_selector</item>
        <item name="android:textSize">18sp</item> <item name="android:gravity">right|center_vertical</item>
        <item name="android:paddingEnd">20dp</item>
        <item name="android:focusable">false</item>
        <item name="android:duplicateParentState">true</item>
    </style>




</resources>