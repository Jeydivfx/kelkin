<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_black"
    android:layoutDirection="rtl"
    android:textDirection="rtl">

    <LinearLayout
        android:id="@+id/panel_details"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:background="#0AFFFFFF"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_percent="0.35">

        <ImageView
            android:id="@+id/img_setting_detail"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_menu_settings"
            app:tint="#FFD700" />

        <TextView
            android:id="@+id/txt_setting_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.3"
            android:text="تنظیمات کلی برنامه کلکین"
            android:textColor="@color/text_white"
            android:textSize="16sp" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/settingsScrollView"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:focusable="false"
        android:paddingVertical="40dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/panel_details"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/settingsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="48dp"
            android:focusable="false"
            android:descendantFocusability="afterDescendants"
            android:gravity="right"> <TextView
            style="@style/SettingHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:layout_marginRight="8dp"
            android:text="پشتیبانی و خدمات سیستم"
            android:textColor="#88FFFFFF"
            android:textSize="14sp"
            android:gravity="right" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cardAbout"
                style="@style/SettingCard"
                android:layout_width="440dp"
                android:layout_height="64dp"
                android:layout_marginBottom="12dp"
                android:focusable="true"
                android:clickable="true"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#1AFFFFFF"
                app:cardElevation="0dp"
                android:nextFocusUp="@id/cardAbout"
                android:nextFocusDown="@id/cardClearCache"
                android:nextFocusLeft="@id/sidebar"
                android:nextFocusRight="@id/sidebar">

                <TextView
                    android:id="@+id/txtAboutDisplay"
                    style="@style/SettingItemText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_marginRight="20dp"
                    android:text="درباره ما و شبکه‌های اجتماعی"
                    android:textColor="@color/text_white"
                    android:textSize="15sp"
                    android:gravity="right" />
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardClearCache"
                style="@style/SettingCard"
                android:layout_width="440dp"
                android:layout_height="64dp"
                android:layout_marginBottom="32dp"
                android:focusable="true"
                android:clickable="true"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#1AFFFFFF"
                app:cardElevation="0dp"
                android:nextFocusUp="@id/cardAbout"
                android:nextFocusDown="@id/cardClearCache"
                android:nextFocusLeft="@id/sidebar"
                android:nextFocusRight="@id/sidebar">

                <TextView
                    android:id="@+id/txtClearDisplay"
                    style="@style/SettingItemText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_marginRight="20dp"
                    android:text="پاکسازی حافظه موقت برنامه"
                    android:textColor="@color/text_white"
                    android:textSize="15sp"
                    android:gravity="right" />
            </androidx.cardview.widget.CardView>

            <View
                android:layout_width="440dp"
                android:layout_height="1dp"
                android:background="#12FFFFFF"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/txtAppVersion"
                android:layout_width="440dp"
                android:layout_height="wrap_content"
                android:layout_marginRight="8dp"
                android:text="نسخه اپلیکیشن: 1.0.0 (Kelkin TV)"
                android:textColor="#55FFFFFF"
                android:textSize="13sp"
                android:gravity="right" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>