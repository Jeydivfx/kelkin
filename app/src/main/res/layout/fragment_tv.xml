<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_black"
    android:padding="24dp"
    android:layoutDirection="rtl">


    <LinearLayout
        android:id="@+id/tvFilterBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="right|center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:focusable="false">

        <com.google.android.material.button.MaterialButton
        android:id="@+id/btnTvCategory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:fontFamily="@font/yekanbakh_regular"
        android:text="همه شبکه‌ها"
        android:textColor="@color/text_white"
        android:textSize="13sp"
        app:strokeColor="#FFFFFF"
        app:strokeWidth="1dp"
        app:rippleColor="#FF9800"
        app:cornerRadius="8dp"
        android:focusable="true"
        app:icon="@drawable/ic_arrow_drop_down"
        app:iconGravity="textStart"
        app:iconPadding="8dp"
        app:iconTint="@color/text_white" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTvSort"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:fontFamily="@font/yekanbakh_regular"
            android:text="ترتیب الفبا"
            android:textColor="@color/text_white"
            android:textSize="13sp"
            app:strokeColor="#FFFFFF"
            app:strokeWidth="1dp"
            app:rippleColor="#FF9800"
            app:cornerRadius="8dp"
            android:focusable="true"
            app:icon="@drawable/ic_arrow_drop_down"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:iconTint="@color/text_white" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTvFavorites"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/yekanbakh_regular"
            android:text="علاقه‌مندی‌ها"
            app:rippleColor="#FF9800"
            android:textColor="@color/text_white"
            android:textSize="13sp"
            app:strokeColor="#FFFFFF"
            app:cornerRadius="8dp"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:iconTint="@color/text_white" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChannels"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingTop="30dp"
        android:clipToPadding="false"
        android:paddingBottom="40dp"
        android:layoutDirection="rtl"
        android:descendantFocusability="afterDescendants"
        android:focusable="false"
        android:focusableInTouchMode="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvFilterBar"
        tools:listitem="@layout/item_channel"
        tools:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
        tools:spanCount="5" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="#FFC107"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>