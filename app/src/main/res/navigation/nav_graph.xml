<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.kelkin.Fragments.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_homeFragment_to_movieDetailFragment"
            app:destination="@id/movieDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/movieDetailFragment"
        android:name="com.example.kelkin.Fragments.MovieDetailFragment"
        android:label="Movie Detail"
        tools:layout="@layout/fragment_movie_detail" />

    <fragment
        android:id="@+id/moviesFragment"
        android:name="com.example.kelkin.Fragments.MoviesFragment"
        android:label="Movies Archive"
        tools:layout="@layout/fragment_movies">
        <action
            android:id="@+id/action_moviesFragment_to_movieDetailFragment"
            app:destination="@id/movieDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/tvFragment"
        android:name="com.example.kelkin.Fragments.TvFragment"
        android:label="Live TV"
        tools:layout="@layout/fragment_tv">
        <action
            android:id="@+id/action_tvFragment_to_homeFragment"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/homeFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/channelListFragment"
        android:name="com.example.kelkin.Fragments.ChannelListFragment"
        android:label="Channel Management"
        tools:layout="@layout/fragment_channel_list" />


    <fragment
        android:id="@+id/adminDashboardFragment"
        android:name="com.example.kelkin.Fragments.AdminDashboardFragment"
        android:label="Admin Dashboard"
        tools:layout="@layout/fragment_admin_dashboard">

        <action
            android:id="@+id/action_adminDashboard_to_movieListFragment"
            app:destination="@id/movieListFragment" />

        <action
            android:id="@+id/action_adminDashboard_to_channelListFragment"
            app:destination="@id/channelListFragment" />

        <action
            android:id="@+id/action_adminDashboard_to_tvListFragment"
            app:destination="@id/channelListFragment" />

    </fragment>

    <fragment
        android:id="@+id/movieListFragment"
        android:name="com.example.kelkin.Fragments.MovieListFragment"
        android:label="Movie List Admin"
        tools:layout="@layout/fragment_movie_list" />


    <fragment
        android:id="@+id/searchFragment"
        android:name="com.example.kelkin.Fragments.SearchFragment"
        android:label="SearchFragment"
        tools:layout="@layout/fragment_search">

        <action
            android:id="@+id/action_searchFragment_to_movieDetailFragment"
            app:destination="@id/movieDetailFragment" />
    </fragment>




    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.example.kelkin.Fragments.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings">

        <action
            android:id="@+id/action_settingsFragment_to_adminDashboardFragment"
            app:destination="@id/adminDashboardFragment" />

    </fragment>

</navigation>