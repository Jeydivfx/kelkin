<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Focused State - Yellow Stroke -->
    <item android:state_focused="true">
        <layer-list>
            <item>
                <shape>
                    <solid android:color="#1A1A1A" />
                    <corners android:radius="12dp" />
                </shape>
            </item>
            <item>
                <shape>
                    <gradient
                        android:startColor="#3DFFFFFF"
                        android:endColor="#15FFFFFF"
                        android:angle="135" />
                    <corners android:radius="12dp" />
                </shape>
            </item>
            <item>
                <shape>
                    <stroke
                        android:width="3dp"
                        android:color="#FFD700" />
                    <corners android:radius="12dp" />
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- Default State -->
    <item>
        <layer-list>
            <item>
                <shape>
                    <solid android:color="#1A1A1A" />
                    <corners android:radius="12dp" />
                </shape>
            </item>
            <item>
                <shape>
                    <gradient
                        android:startColor="#3DFFFFFF"
                        android:endColor="#15FFFFFF"
                        android:angle="135" />
                    <corners android:radius="12dp" />
                </shape>
            </item>
            <item>
                <shape>
                    <stroke
                        android:width="0.5dp"
                        android:color="#20FFFFFF" />
                    <corners android:radius="12dp" />
                </shape>
            </item>
        </layer-list>
    </item>

</selector>